#include <avr/io.h>
#include <avr/interrupt.h>

volatile uint8_t countdown_ms = 0;   

ISR(INT0_vect) {                    // Button on D2 (PD2), falling edge
    PORTB |= (1 << PB5);            // LED ON (D13 = PB5)
    countdown_ms = 10;              // 10 ms pulse

    TCNT1 = 0;                     
    TIFR1 = (1 << OCF1A);           // clear pending compare match flag
}

ISR(TIMER1_COMPA_vect) {            // 1 ms tick
    if (countdown_ms) {
        if (--countdown_ms == 0) {
            PORTB &= ~(1 << PB5);   // LED OFF
        }
    }
}

int main(void) {
    // --- LED output (D13 = PB5) ---
    DDRB |= (1 << DDB5);
    PORTB &= ~(1 << PB5);

    // --- Button input (D2 = PD2) with pull-up ---
    DDRD &= ~(1 << DDD2);
    PORTD |= (1 << PORTD2);

    // --- External interrupt INT0 on falling edge ---
    EICRA = (1 << ISC01);           // ISC01=1, ISC00=0 -> falling edge
    EIMSK = (1 << INT0);            // enable INT0

    // --- Timer1 CTC, 1 ms interval ---
    TCCR1A = 0;
    TCCR1B = (1 << WGM12) | (1 << CS11) | (1 << CS10); 
    OCR1A  = 249;                   
    TIMSK1 = (1 << OCIE1A);         

    sei();

    while (1) { }                   // main loop must be empty
}
